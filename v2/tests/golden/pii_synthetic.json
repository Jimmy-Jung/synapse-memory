{
  "version": "1.0",
  "description": "PII redaction 정확도 측정용 합성 골든셋. 한국어 위주 + 영어 혼합.",
  "author": "JunyoungJung <joony300@gmail.com>",
  "created": "2026-05-10",
  "notes": [
    "expected: 정답 라벨. 카테고리 + 정확한 텍스트.",
    "negative case는 expected: []",
    "Pass 1(regex)와 Pass 2(LLM) 카테고리 모두 포함."
  ],
  "samples": [
    {"id": "email-001", "text": "연락처: foo@bar.com", "expected": [{"category": "email", "value": "foo@bar.com"}]},
    {"id": "email-002", "text": "이메일은jimmy@megastudy.net이고", "expected": [{"category": "email", "value": "jimmy@megastudy.net"}]},
    {"id": "email-003", "text": "이메일 hong@megastudy.net.", "expected": [{"category": "email", "value": "hong@megastudy.net"}]},
    {"id": "email-004", "text": "user+tag@domain.com 으로 보내주세요", "expected": [{"category": "email", "value": "user+tag@domain.com"}]},
    {"id": "email-005", "text": "두 번: a@x.com 그리고 a@x.com 또 b@y.com", "expected": [{"category": "email", "value": "a@x.com"}, {"category": "email", "value": "a@x.com"}, {"category": "email", "value": "b@y.com"}]},

    {"id": "phone-001", "text": "전화 010-1234-5678로 연락", "expected": [{"category": "phone_kr", "value": "010-1234-5678"}]},
    {"id": "phone-002", "text": "010 1234 5678 (공백 구분)", "expected": [{"category": "phone_kr", "value": "010 1234 5678"}]},
    {"id": "phone-003", "text": "+82-10-1234-5678 국제번호", "expected": [{"category": "phone_kr", "value": "+82-10-1234-5678"}]},
    {"id": "phone-004", "text": "서울 02-123-4567 사무실", "expected": [{"category": "phone_kr", "value": "02-123-4567"}]},
    {"id": "phone-005", "text": "전화010-9999-8888로", "expected": [{"category": "phone_kr", "value": "010-9999-8888"}]},

    {"id": "card-001", "text": "카드: 4242-4242-4242-4242", "expected": [{"category": "card", "value": "4242-4242-4242-4242"}]},
    {"id": "card-002", "text": "Mastercard 5555 5555 5555 4444", "expected": [{"category": "card", "value": "5555 5555 5555 4444"}]},
    {"id": "card-003", "text": "no separator: 4111111111111111", "expected": [{"category": "card", "value": "4111111111111111"}]},
    {"id": "card-neg-001", "text": "Luhn 실패: 1234-5678-9012-3456", "expected": []},
    {"id": "card-neg-002", "text": "Luhn 실패: 4242-4242-4242-4243", "expected": []},

    {"id": "rrn-001", "text": "주민번호: 001231-1234560", "expected": [{"category": "rrn", "value": "001231-1234560"}]},
    {"id": "rrn-002", "text": "valid RRN 9401011234567", "expected": [{"category": "rrn", "value": "9401011234567"}]},
    {"id": "rrn-neg-001", "text": "체크섬 실패 001231-1234561", "expected": []},
    {"id": "rrn-neg-002", "text": "랜덤 13자리 1234567890123", "expected": []},
    {"id": "rrn-neg-003", "text": "월 초과 001399-1234567", "expected": []},

    {"id": "jwt-001", "text": "token: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c", "expected": [{"category": "jwt", "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c"}]},
    {"id": "jwt-neg-001", "text": "단순 base64 eyJabc 만으로는 매치 안 됨", "expected": []},

    {"id": "apikey-001", "text": "export OPENAI_API_KEY=sk-abcdefghij1234567890XYZ", "expected": [{"category": "api_key_sk", "value": "sk-abcdefghij1234567890XYZ"}]},
    {"id": "apikey-002", "text": "github token: ghp_AAAABBBBCCCCDDDDEEEEFFFFGGGGHHHHIIII", "expected": [{"category": "api_key_github", "value": "ghp_AAAABBBBCCCCDDDDEEEEFFFFGGGGHHHHIIII"}]},
    {"id": "apikey-003", "text": "AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE", "expected": [{"category": "aws_key", "value": "AKIAIOSFODNN7EXAMPLE"}]},
    {"id": "apikey-004", "text": "Authorization: Bearer abcdef1234567890XYZ token", "expected": [{"category": "bearer", "value": "Bearer abcdef1234567890XYZ"}]},

    {"id": "ipv4-001", "text": "server: 192.168.1.1", "expected": [{"category": "ipv4", "value": "192.168.1.1"}]},
    {"id": "ipv4-002", "text": "DNS는 8.8.8.8 사용", "expected": [{"category": "ipv4", "value": "8.8.8.8"}]},
    {"id": "ipv4-neg-001", "text": "유효 안 함: 999.999.999.999", "expected": []},

    {"id": "person-001", "text": "홍길동에게 연락 부탁", "expected": [{"category": "person_name", "value": "홍길동"}]},
    {"id": "person-002", "text": "김철수와 박영희가 회의 참석", "expected": [{"category": "person_name", "value": "김철수"}, {"category": "person_name", "value": "박영희"}]},
    {"id": "person-003", "text": "John Smith가 화상회의 호스트", "expected": [{"category": "person_name", "value": "John Smith"}]},
    {"id": "person-004", "text": "이순신과 강감찬 둘 다", "expected": [{"category": "person_name", "value": "이순신"}, {"category": "person_name", "value": "강감찬"}]},
    {"id": "person-005", "text": "Mike와 박민수 협업", "expected": [{"category": "person_name", "value": "Mike"}, {"category": "person_name", "value": "박민수"}]},
    {"id": "person-006", "text": "남궁선재가 발표함", "expected": [{"category": "person_name", "value": "남궁선재"}]},
    {"id": "person-neg-001", "text": "사용자 jimmy가 GitHub에 commit", "expected": []},
    {"id": "person-neg-002", "text": "User Assistant System role", "expected": []},
    {"id": "person-neg-003", "text": "session: xoAP7Qtf 처리", "expected": []},
    {"id": "person-neg-004", "text": "/Users/jimmy/Documents 경로", "expected": []},
    {"id": "person-neg-005", "text": "Jimmy-Jung GitHub handle", "expected": []},

    {"id": "org-001", "text": "메가스터디 본사 방문", "expected": [{"category": "org_name", "value": "메가스터디"}]},
    {"id": "org-002", "text": "당근마켓에 지원할 예정", "expected": [{"category": "org_name", "value": "당근마켓"}]},
    {"id": "org-neg-001", "text": "GitHub repo 생성", "expected": []},
    {"id": "org-neg-002", "text": "Apple 신제품 출시", "expected": []},
    {"id": "org-neg-003", "text": "claude로 작업, codex CLI 사용", "expected": []},
    {"id": "org-neg-004", "text": "SessionStart:startup hook 발생", "expected": []},

    {"id": "address-001", "text": "주소: 서울시 강남구 테헤란로 123", "expected": [{"category": "address", "value": "서울시 강남구 테헤란로 123"}]},
    {"id": "address-002", "text": "부산광역시 해운대구 해운대로 456 빌딩", "expected": [{"category": "address", "value": "부산광역시 해운대구 해운대로 456"}]},
    {"id": "address-neg-001", "text": "단순 도시: 서울에서 만나요", "expected": []},
    {"id": "address-neg-002", "text": "/Users/jimmy/Documents 경로", "expected": []},

    {"id": "secret-001", "text": "내 비밀번호는 dansim2024 야", "expected": [{"category": "secret", "value": "dansim2024"}]},
    {"id": "secret-002", "text": "토큰: abc123def456 사용", "expected": [{"category": "secret", "value": "abc123def456"}]},

    {"id": "mixed-001", "text": "홍길동(010-1234-5678, hong@megastudy.net)", "expected": [{"category": "person_name", "value": "홍길동"}, {"category": "phone_kr", "value": "010-1234-5678"}, {"category": "email", "value": "hong@megastudy.net"}]},
    {"id": "mixed-002", "text": "김철수 010-1111-2222 카드 4242-4242-4242-4242", "expected": [{"category": "person_name", "value": "김철수"}, {"category": "phone_kr", "value": "010-1111-2222"}, {"category": "card", "value": "4242-4242-4242-4242"}]},
    {"id": "mixed-003", "text": "당근마켓 채용 — John Smith 추천. 서버 192.168.1.1.", "expected": [{"category": "org_name", "value": "당근마켓"}, {"category": "person_name", "value": "John Smith"}, {"category": "ipv4", "value": "192.168.1.1"}]},

    {"id": "clean-001", "text": "오늘 날씨가 화창하다", "expected": []},
    {"id": "clean-002", "text": "Python 3.13으로 작업 중. iOS 26.2 환경.", "expected": []},
    {"id": "clean-003", "text": "git commit -m \"feat: add login\"", "expected": []}
